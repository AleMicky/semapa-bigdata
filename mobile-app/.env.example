# API Gateway (backend en Docker, puerto 3000 en el host)
#
# Emulador Android: 10.0.2.2 apunta al localhost de tu Mac
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
#
# Simulador iOS o Expo Go en la misma red: usa localhost o tu IP LAN
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# Emulador Android por defecto (opcional)
# ANDROID_AVD=S23_API_33
